# Copy to `.env.local` and fill in secret values. `.env.local` is gitignored.

# Public site URL — canonical links, Open Graph, RSS, JSON-LD (`NEXT_PUBLIC_SITE_URL`).
# Production (example): https://www.after-certainty.com
# Local dev — optional; subscribe route and metadata fall back to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Beehiiv — required for POST /api/subscribe (newsletter form on the book microsite).
# Dashboard: publication settings → API → create key and copy publication ID.
NEWSLETTER_API_KEY=
NEWSLETTER_PUBLICATION_ID=

# Podcast — server-side RSS fetch for `/podcast` (ISR ~1h). Falls back to `data/podcast-episodes.json` if unset or unreachable.
PODCAST_RSS_URL=

# Optional listening / directory links (shown on `/podcast`). Defaults exist for Spotify / RSS / GitHub when unset.
# NEXT_PUBLIC_PODCAST_SPOTIFY_URL=
# NEXT_PUBLIC_PODCAST_APPLE_URL=
# NEXT_PUBLIC_PODCAST_YOUTUBE_URL=
# NEXT_PUBLIC_GITHUB_DISCUSSIONS_URL=
