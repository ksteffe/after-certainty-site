# Copy to `.env.local` and fill in secret values. `.env.local` is gitignored.

# Public site URL — canonical links, Open Graph, RSS, JSON-LD (`NEXT_PUBLIC_SITE_URL`).
# Production (example): https://www.after-certainty.com
# Local dev — optional; subscribe route and metadata fall back to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Beehiiv — required for POST /api/subscribe (newsletter form on the book microsite).
# Dashboard: publication settings → API → create key and copy publication ID.
NEWSLETTER_API_KEY=
NEWSLETTER_PUBLICATION_ID=

# Podcast — server-side RSS fetch for `/podcast` (ISR ~1h). Falls back to `data/podcast-episodes.json` if unset or unreachable.
PODCAST_RSS_URL=

# On-demand cache refresh — POST /api/cache/revalidate with `Authorization: Bearer <secret>`.
# Revalidates podcast RSS, semantic graph, and books catalog manifest fetches. Set in production only.
# CACHE_REVALIDATE_SECRET=

# Semantic graph — server-side fetch of `semantic-manifest.json` from GitHub releases (ISR). See `lib/graph/manifest.ts`.
# SEMANTIC_MANIFEST_URL=
# SEMANTIC_MANIFEST_REVALIDATE_SECONDS=3600
# SEMANTIC_MANIFEST_OFFLINE=1

# Books catalog — server-side fetch of generated `books-manifest.json` from GitHub releases (ISR). Falls back to `data/books-manifest.json` if unreachable.
# BOOKS_MANIFEST_URL=
# Revalidate interval in seconds (default 3600). Optional override:
# BOOKS_MANIFEST_REVALIDATE_SECONDS=3600
# Skip network and use bundled JSON only (e.g. CI): BOOKS_MANIFEST_OFFLINE=1

# Optional listening / directory links (shown on `/podcast`). Defaults exist for Spotify / RSS / GitHub when unset.
# NEXT_PUBLIC_PODCAST_SPOTIFY_URL=
# NEXT_PUBLIC_PODCAST_APPLE_URL=
# NEXT_PUBLIC_PODCAST_YOUTUBE_URL=
# NEXT_PUBLIC_GITHUB_DISCUSSIONS_URL=

# Site footer social icons (`resolveSiteSocialLinks`). Optional overrides:
# NEXT_PUBLIC_SOCIAL_GITHUB_URL=
# NEXT_PUBLIC_SOCIAL_MEDIUM_URL=
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=
